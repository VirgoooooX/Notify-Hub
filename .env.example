# Copy to .env for Compose. Never commit real credentials.
NOTIFY_HUB_ENVIRONMENT=production
NOTIFY_HUB_APP_TIMEZONE=Asia/Shanghai
NOTIFY_HUB_PUBLIC_BASE_URL=https://notify.example.com
NOTIFY_HUB_LOG_LEVEL=INFO

# SQLite is the supported v0.3.0 single-instance database.
NOTIFY_HUB_DATABASE_URL=sqlite+aiosqlite:////data/notify-hub.db
NOTIFY_HUB_MEDIA_ROOT=/media
NOTIFY_HUB_LOG_DIR=/logs
NOTIFY_HUB_MEDIA_IMAGE_MAX_BYTES=2097152
NOTIFY_HUB_MEDIA_VOICE_MAX_BYTES=2097152
NOTIFY_HUB_MEDIA_VOICE_MAX_SECONDS=60
NOTIFY_HUB_MEDIA_DOWNLOAD_TIMEOUT_SECONDS=20
NOTIFY_HUB_MEDIA_DOWNLOAD_MAX_REDIRECTS=3
NOTIFY_HUB_MEDIA_RETENTION_SECONDS=2592000

# ASR, TTS, and transcoding are optional adapters. Empty values disable them;
# provider SDKs, model runtimes, and model weights are not bundled in the image.
NOTIFY_HUB_ASR_COMMAND=[]
NOTIFY_HUB_TTS_COMMAND=[]
NOTIFY_HUB_TRANSCODE_COMMAND=[]

# Non-secret WeCom identifiers. Leave blank until the channel is configured.
NOTIFY_HUB_WECOM_CORP_ID=
NOTIFY_HUB_WECOM_AGENT_ID=
# Optional trusted HTTPS reverse proxy. A path prefix is supported.
NOTIFY_HUB_WECOM_API_BASE_URL=https://qyapi.weixin.qq.com
NOTIFY_HUB_WECOM_CALLBACK_REPLAY_WINDOW_SECONDS=300
NOTIFY_HUB_WECOM_CALLBACK_MAX_BODY_BYTES=1048576
NOTIFY_HUB_REMINDER_POLL_SECONDS=5

# Secrets are read from files mounted read-only at /run/secrets. Create these
# files locally; do not place their values in this example or in version control.
NOTIFY_HUB_SECRET_ENCRYPTION_KEY_FILE=/run/secrets/app_master_key
NOTIFY_HUB_JWT_SECRET_FILE=/run/secrets/jwt_secret
NOTIFY_HUB_WECOM_SECRET_FILE=/run/secrets/wecom_secret
NOTIFY_HUB_WECOM_CALLBACK_TOKEN_FILE=/run/secrets/wecom_callback_token
NOTIFY_HUB_WECOM_CALLBACK_AES_KEY_FILE=/run/secrets/wecom_callback_aes_key
