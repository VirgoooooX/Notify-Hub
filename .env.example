# Copy to .env for Docker Compose. Never commit real credentials.
NOTIFY_HUB_ENVIRONMENT=production
NOTIFY_HUB_PUBLIC_BASE_URL=https://notify.example.com

# WeCom Channel config
NOTIFY_HUB_WECOM_CORP_ID=
NOTIFY_HUB_WECOM_AGENT_ID=
NOTIFY_HUB_WECOM_API_BASE_URL=https://qyapi.weixin.qq.com
NOTIFY_HUB_ALLOW_BROADCAST=true

# Secrets. Set these values locally in your .env file.
# Keep them strong (at least 32 characters) in production.
NOTIFY_HUB_SECRET_ENCRYPTION_KEY=
NOTIFY_HUB_JWT_SECRET=
NOTIFY_HUB_WECOM_SECRET=
NOTIFY_HUB_WECOM_CALLBACK_TOKEN=
NOTIFY_HUB_WECOM_CALLBACK_AES_KEY=

# Optional AI Gateway bootstrap. Leave disabled/blank to configure later in the admin UI.
NOTIFY_HUB_AI_ENABLED=false
NOTIFY_HUB_AI_BOOTSTRAP_PRESET=custom
NOTIFY_HUB_AI_BOOTSTRAP_BASE_URL=
NOTIFY_HUB_AI_BOOTSTRAP_MODEL=
NOTIFY_HUB_AI_BOOTSTRAP_API_KEY=
